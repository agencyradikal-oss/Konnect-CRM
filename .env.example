# ============ Konnect™ — Variables de entorno ============
# Copia este archivo a .env y completa los valores.

# PostgreSQL (Neon pooled — runtime)
# Ejemplo Neon: postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=""

# Misma DB sin pooler (migraciones). En Neon: connection string "direct".
# Si usas una sola URL local, copia DATABASE_URL aquí.
DATABASE_URL_UNPOOLED=""

# Clerk (OAuth Google + email/password) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Webhook endpoint: /api/webhooks/clerk (eventos user.created/updated/deleted)
CLERK_WEBHOOK_SIGNING_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/signup"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/app/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/registrar-empresa"

# Geocoding (opcional) — si no hay key se usa Nominatim (gratis)
GOOGLE_GEOCODING_API_KEY=""

# Stripe Billing (planes Free / Pro / Premium)
# Crear precios: STRIPE_SECRET_KEY=sk_... node scripts/create-stripe-products.mjs
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_PREMIUM=""

# Vercel Blob — store público (logos, portadas, galería del directorio)
BLOB_PUBLIC_READ_WRITE_TOKEN=""
BLOB_PUBLIC_STORE_ID=""
# Para verificar webhooks de client uploads (opcional por ahora)
BLOB_PUBLIC_WEBHOOK_PUBLIC_KEY=""
# Legacy (fallback si aún no migraste a BLOB_PUBLIC_*)
# BLOB_READ_WRITE_TOKEN=""
# BLOB_STORE_ID=""

# Resend (emails transaccionales)
RESEND_API_KEY=""

# Cron Vercel — Authorization: Bearer … en /api/cron/weekly-leads
CRON_SECRET=""

# URL pública de la app (sin slash final)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
