// Konnect™ — schema núcleo
// https://konnect.kmd.agency

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Neon pooler (DATABASE_URL) + conexión directa para migraciones
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============ Auth / Tenant ============

model User {
  id           String    @id @default(cuid())
  /// ID de Clerk (`user_...`). Auth OAuth / email-password vive en Clerk.
  clerkUserId  String?   @unique
  email        String    @unique
  name         String?
  /// Legacy Auth.js — ya no se usa para login (contraseñas en Clerk).
  passwordHash String?
  role         Role      @default(BUSINESS_OWNER)
  businessId   String?
  business     Business? @relation(fields: [businessId], references: [id])
  /// Si true, no puede iniciar sesión (gestión desde /admin/usuarios).
  disabled     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  googleConnections GoogleConnection[]
  appointmentsCreated Appointment[] @relation("AppointmentCreator")

  @@index([businessId])
  @@index([role])
  @@index([disabled])
}

enum Role {
  SUPER_ADMIN
  BUSINESS_OWNER
  BUSINESS_STAFF
}

// ============ Directorio público ============

model Business {
  id                   String         @id @default(cuid())
  slug                 String         @unique // /negocio/[slug]
  name                 String
  description          String?        @db.Text
  categoryId           String
  category             Category       @relation(fields: [categoryId], references: [id])
  phone                String?
  whatsapp             String?
  email                String?
  website              String?
  address              String?
  city                 String?
  state                String?        @default("GA")
  zip                  String?
  lat                  Float?
  lng                  Float?
  logoUrl              String?
  coverUrl             String?
  gallery              String[] // URLs Vercel Blob
  hours                Json? // horario por día
  socials              Json? // fb, ig, tiktok, linkedin
  languages            String[]       @default(["es", "en"])
  verified             Boolean        @default(false)
  featured             Boolean        @default(false) // solo Premium
  plan                 Plan           @default(FREE)
  /// Premium lifetime de cortesía (socio). Stripe no puede degradar el plan.
  planCourtesy         Boolean        @default(false)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  /// Webhook de salida (Zapier/Make → Square/QuickBooks, etc.)
  webhookUrl           String?
  webhookSecret        String?
  webhookEnabled       Boolean        @default(false)
  status               BusinessStatus @default(PENDING)
  users                User[]
  leads                Lead[]
  contacts             Contact[]
  deals                Deal[]
  tasks                Task[]
  activities           Activity[]
  reviews              Review[]
  pageViews            PageView[]
  planCourtesyGrants   PlanCourtesyEntitlement[]
  googleConnections    GoogleConnection[]
  appointments         Appointment[]
  apiKeys              BusinessApiKey[]
  createdAt            DateTime       @default(now())

  @@index([categoryId])
  @@index([city, status])
  @@index([plan, featured])
  @@index([stripeCustomerId])
  @@index([planCourtesy])
}

/// API keys de partners (Authorization: Bearer kn_live_…).
model BusinessApiKey {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  /// Prefijo visible (ej. kn_live_ab12)
  prefix     String
  /// SHA-256 hex del secret completo
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([businessId])
  @@index([keyHash])
  @@index([revokedAt])
}

/// Emails de socios con Premium lifetime de cortesía (pendiente o aplicado).
model PlanCourtesyEntitlement {
  id         String    @id @default(cuid())
  email      String    @unique
  plan       Plan      @default(PREMIUM)
  note       String?
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  grantedAt  DateTime  @default(now())
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([businessId])
  @@index([revokedAt])
}

enum Plan {
  FREE
  PRO
  PREMIUM
}

enum BusinessStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Category {
  id         String     @id @default(cuid())
  slug       String     @unique
  nameEs     String
  nameEn     String
  icon       String?
  parentId   String?
  parent     Category?  @relation("Sub", fields: [parentId], references: [id])
  children   Category[] @relation("Sub")
  businesses Business[]

  @@index([parentId])
}

model Review {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id])
  authorName  String
  authorEmail String
  rating      Int // 1-5 (validar en Zod)
  comment     String?  @db.Text
  approved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([businessId, approved])
}

// ============ CRM (privado, por tenant) ============

model Lead {
  id         String     @id @default(cuid())
  businessId String
  business   Business   @relation(fields: [businessId], references: [id])
  name       String
  email      String?
  phone      String?
  message    String?    @db.Text
  source     LeadSource
  status     LeadStatus @default(NEW)
  contactId  String?
  contact    Contact?   @relation(fields: [contactId], references: [id])
  dealId     String?
  deal       Deal?      @relation(fields: [dealId], references: [id])
  appointments Appointment[]
  createdAt  DateTime   @default(now())

  @@index([businessId, status])
  @@index([businessId, source])
  @@index([contactId])
  @@index([dealId])
}

enum LeadSource {
  DIRECTORY_FORM
  QUOTE_REQUEST
  CLICK_CALL
  CLICK_WHATSAPP
  MANUAL
  IMPORT
  REFERRAL
  BOOKING
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Contact {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id])
  name       String
  email      String?
  phone      String?
  company    String?
  notes      String?  @db.Text
  tags       String[]
  deals      Deal[]
  leads      Lead[]
  appointments Appointment[]
  createdAt  DateTime @default(now())

  @@index([businessId])
}

model Deal {
  id            String     @id @default(cuid())
  businessId    String
  business      Business   @relation(fields: [businessId], references: [id])
  contactId     String?
  contact       Contact?   @relation(fields: [contactId], references: [id])
  title         String
  value         Decimal?   @db.Decimal(12, 2)
  stage         DealStage  @default(NUEVO)
  expectedClose DateTime?
  notes         String?    @db.Text
  tasks         Task[]
  activities    Activity[]
  leads         Lead[]
  appointments  Appointment[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([businessId, stage])
  @@index([contactId])
}

enum DealStage {
  NUEVO
  CONTACTADO
  COTIZADO
  NEGOCIACION
  GANADO
  PERDIDO
}

model Task {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id])
  title      String
  dueDate    DateTime?
  done       Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([businessId, done])
  @@index([dealId])
}

model Activity {
  id         String   @id @default(cuid())
  businessId String // denormalizado para queries multi-tenant
  business   Business @relation(fields: [businessId], references: [id])
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id])
  type       String // note | call | email | stage_change | created
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([dealId, createdAt])
}

/// Rate limit de formularios públicos (máx N envíos / hora por IP).
model LeadRateLimit {
  id        String   @id @default(cuid())
  ipHash    String
  createdAt DateTime @default(now())

  @@index([ipHash, createdAt])
}

/// Vistas del perfil público (analytics Premium).
model PageView {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  slug       String
  createdAt  DateTime @default(now())

  @@index([businessId, createdAt])
  @@index([slug, createdAt])
}

// ============ Google (Calendar / Maps / GBP) ============

/// OAuth Google por usuario+negocio (distinto del login Clerk).
model GoogleConnection {
  id                 String    @id @default(cuid())
  businessId         String
  business           Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleAccountEmail String?
  accessTokenEnc     String    @db.Text
  refreshTokenEnc    String    @db.Text
  expiresAt          DateTime?
  scopes             String[]
  calendarEnabled    Boolean   @default(true)
  gbpEnabled         Boolean   @default(false)
  /// Resource name GBP: accounts/xxx/locations/yyy
  gbpLocationName    String?
  consentAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([businessId, userId])
  @@index([businessId])
}

enum AppointmentType {
  MEASURE
  VISIT
  CALL
  OTHER
}

enum AppointmentStatus {
  SCHEDULED
  DONE
  CANCELED
}

/// Cita de medida/visita (verdad en Konnect; espejo en Google Calendar).
model Appointment {
  id               String            @id @default(cuid())
  businessId       String
  business         Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  dealId           String?
  deal             Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  leadId           String?
  lead             Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdByUserId  String?
  createdBy        User?             @relation("AppointmentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  type             AppointmentType   @default(MEASURE)
  title            String
  notes            String?           @db.Text
  status           AppointmentStatus @default(SCHEDULED)
  startsAt         DateTime
  endsAt           DateTime
  timezone         String            @default("America/New_York")
  address          String?
  city             String?
  state            String?           @default("GA")
  zip              String?
  lat              Float?
  lng              Float?
  googleEventId    String?
  googleCalendarId String?
  mapsUrl          String?
  /// Orden en la ruta del día (menor = primero).
  routeOrder       Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([businessId, startsAt])
  @@index([businessId, status])
  @@index([contactId])
  @@index([dealId])
  @@index([leadId])
}
